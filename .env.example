# =============================================================================
# Ampex Mobile – miljøvariabler
# Kopier:  cp .env.example .env
# Hent Supabase-verdier: Dashboard → Project Settings → API
# =============================================================================

# Påkrevd
APP_ENV=dev
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Valgfritt (prosjekt-referanse – kun dokumentasjon/debug)
# SUPABASE_PROJECT_REF=your-project-ref

# Valgfritt – S3-kompatibel lagring (fase 1+ filopplasting)
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3_BUCKET=ampex-dev
# S3_REGION=auto
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
